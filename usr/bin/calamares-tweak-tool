#!/bin/sh
# Launch the Calamares Tweak Tool. Dev/expert panel that flips the live ISO's
# Calamares encryption + bootloader settings before you launch the installer.
# Edits the live /etc/calamares by default; pass --config-dir DIR to point elsewhere.
APP=/usr/share/calamares-tweak-tool/main.py

# Already root (live ISO, or `sudo -E`): run directly, no polkit needed.
if [ "$(id -u)" = 0 ]; then
    exec python "$APP" "$@"
fi

# Not root: escalate via polkit (/etc/calamares is root:root, so saving needs root).
# IMPORTANT — do NOT `exec` pkexec. A menu launch (gtk-launch / budgie) fires the
# launcher and exits immediately; with `exec`, pkexec's parent is then already dead
# and it aborts with "Refusing to render service to dead parents". Keeping this shell
# alive as pkexec's parent satisfies that check. (ATT's wrapper avoids `exec` too.)
RT="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"

# Detect Wayland by socket / session type, NOT just $WAYLAND_DISPLAY — a menu launch
# may not propagate that env var even inside a Wayland session.
if [ "$XDG_SESSION_TYPE" = "wayland" ] || [ -n "$WAYLAND_DISPLAY" ] || [ -S "$RT/wayland-0" ]; then
    # Wayland (e.g. Budgie): force Qt's Wayland platform + software GL. No xcb/XWayland
    # fallback — as root it has no X cookie and coredumps, and VM EGL leaves the window
    # unpainted. Mirrors archlinux-tweak-tool's proven Wayland recipe.
    pkexec env \
        WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-0}" \
        XDG_RUNTIME_DIR="$RT" \
        QT_QPA_PLATFORM=wayland \
        LIBGL_ALWAYS_SOFTWARE=1 \
        python "$APP" "$@"
else
    # X11: pass the X display + auth; Qt's default xcb backend — zero change on X11.
    pkexec env \
        DISPLAY="$DISPLAY" \
        XAUTHORITY="$XAUTHORITY" \
        python "$APP" "$@"
fi
